<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:padding="8dp">
    <TextView android:id="@+id/tvIngredientName"
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content" android:textStyle="bold"/>
    <TextView android:id="@+id/tvIngredientVolume"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"/>
    <ImageButton android:id="@+id/btnDeleteIngredient"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:src="@android:drawable/ic_delete" android:background="?attr/selectableItemBackgroundBorderless"/>
</LinearLayout>